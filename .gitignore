# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/.test-dist

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
*.log.*
/.npm-cache
/logs/

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local database
/data/*.db
/data/*.db-*
/data/*.sqlite
/data/*.sqlite-*
/backups/*
!/backups/.gitkeep
/backup.config.json

# vercel
.vercel

# local caches and temporary files
/.turbo/
/.cache/
/tmp/
/temp/
*.tmp
*.temp
Thumbs.db

# typescript
*.tsbuildinfo
next-env.d.ts
